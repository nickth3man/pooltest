    "@vitest/eslint-plugin": "^1.6.9",
    "@vitest/ui": "^4.0.18",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "jsdom": "^23.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
